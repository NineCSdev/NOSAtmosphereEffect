<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fine Tuning"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutPollInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Unlock Check Interval (ms)"
                app:helperText="Recommended for\nOthers: 50ms | Samsung: 30000ms"
                app:helperTextTextColor="@color/white_alpha_70"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_info"
                app:endIconTint="@color/brand_primary"
                app:endIconContentDescription="More Info"
                android:layout_marginBottom="24dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputPollInterval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/white"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutLockDelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Lock Delay (ms)"
                app:helperText="Recommended for\nOthers: 800ms | Samsung: 0ms"
                app:helperTextTextColor="@color/white_alpha_70"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_info"
                app:endIconTint="@color/brand_primary"
                app:endIconContentDescription="More Info"
                android:layout_marginBottom="24dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputLockDelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/white"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Animation Duration (ms)"
                app:helperText="Recommended for\nOriginal: 2500ms | Reverse: 1500ms | Others: 500ms"
                app:helperTextTextColor="@color/white_alpha_70"
                android:layout_marginBottom="32dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputAnimDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/white"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutRotationContainer"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Playlist Rotation Mode"
                app:helperText="Intervals, or sync Image 1(Light)/Image 2(Dark)"
                app:helperTextTextColor="@color/white_alpha_70"
                android:layout_marginBottom="24dp">

                <AutoCompleteTextView
                    android:id="@+id/dropdownRotation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:popupBackground="@color/black"
                    android:textColor="@color/white"/>
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/halftoneSettingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Halftone Pixel Size"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderDotSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="40.0"
                    android:value="12.0"
                    android:stepSize="1.0" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchGrayscale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Black &amp; White Effect"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/colorFillSettingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fingerprint Position (Horizontal)"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderOriginX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:value="0.5"
                    android:stepSize="0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fingerprint Position (Vertical)"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderOriginY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:value="0.8"
                    android:stepSize="0.01"
                    android:layout_marginBottom="24dp"/>
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchNoise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Blur Noise (Film Grain)"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginBottom="32dp"
                app:thumbTint="@color/brand_primary"
                app:trackTint="@color/brand_on_primary"/>

            <LinearLayout
                android:id="@+id/layoutNoiseSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Noise Scale (Grain Size)"
                    app:helperText="Lower = Larger Grains. Recommended: 2000"
                    app:helperTextTextColor="@color/white_alpha_70"
                    android:layout_marginBottom="24dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputNoiseScale"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Noise Strength (Intensity)"
                    app:helperText="0.0 to 1.0. Recommended: 0.06"
                    app:helperTextTextColor="@color/white_alpha_70"
                    android:layout_marginBottom="32dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputNoiseStrength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/blobColorSettingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blob Saturation"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderSaturation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="3.0"
                    android:value="1.0"
                    android:stepSize="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blob Contrast"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderContrast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="3.0"
                    android:value="1.0"
                    android:stepSize="0.1"
                    android:layout_marginBottom="24dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplyAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:text="Save &amp; Apply"
                android:layout_marginBottom="16dp"
                app:cornerRadius="28dp"
                android:backgroundTint="@color/brand_primary"
                android:textColor="@color/brand_on_primary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetDefaults"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:text="Reset to Recommended"
                app:cornerRadius="28dp"
                android:textColor="@color/white"
                app:strokeColor="@color/white_alpha_70"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>